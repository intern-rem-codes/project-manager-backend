// prisma/schema.prisma
datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
}

model Client {
  id          Int       @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String    @unique
  phone       String?
  dateOfBirth DateTime?
  street      String?
  city        String?
  postalCode  String?
  country     String?

  projects Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  status      String
  deadline    String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])
}
