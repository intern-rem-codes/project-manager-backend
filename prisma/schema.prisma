// prisma/schema.prisma
datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           Int    @id @default(autoincrement())
  name         String
  email        String @unique
  passwordHash String @default("")
  lastName     String?
  phone        String?
  street       String?
  city         String?
  postalCode   String?
  country      String?

  role             UserRole @default(USER)
  isActive         Boolean  @default(true)
  personalClientId Int?
  personalClient   Client?  @relation("PersonalClient", fields: [personalClientId], references: [id])

  projects Project[] @relation("OwnerProjects")
}

model Client {
  id          Int       @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String    @unique
  phone       String?
  dateOfBirth DateTime?
  street      String?
  city        String?
  postalCode  String?
  country     String?

  personalFor User[] @relation("PersonalClient")
  projects Project[]
}

model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  status      String
  deadline    String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  clientId Int
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  ownerId Int?
  owner   User? @relation("OwnerProjects", fields: [ownerId], references: [id], onDelete: SetNull)
}
